# ── LLM ──────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M
OLLAMA_NUM_GPU=1              # set 0 for CPU-only mode

# ── Vector DB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=humanmaximizer_knowledge
CHROMA_PERSIST_DIR=./chroma_db

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/leads.db
# Swap to PostgreSQL with one change:
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# ── Search ────────────────────────────────────────────────────────────────────
SERPAPI_KEY=                  # required for live company search via SerpAPI

# ── Observability (all optional) ──────────────────────────────────────────────
LANGCHAIN_API_KEY=            # LangSmith tracing key
LANGCHAIN_PROJECT=humanmaximizer-lead-gen
LANGCHAIN_TRACING_V2=true
SLACK_WEBHOOK_URL=            # Slack alert webhook (production)

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
